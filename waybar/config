{
    "layer": "top",
    "position": "top",
    "output": "HDMI-A-1",
    "height": 24,
    "margin-left": 0,
    "margin-bottom": 0,
    "margin-right": 0,
    "spacing": 0,
    "modules-left": [
        "custom/power",
        "custom/search",
        "hyprland/workspaces"
    ],
    "modules-center": [],
    "modules-right": [
        "tray",
        "cpu",
        "custom/gpu",
        "memory",
        "disk",
        "battery",
        "custom/sound",
        "clock"
    ],
    "custom/power": {
        "format": "󰐥 ",
        "tooltip": false,
        "on-click": "~/.config/rofi/powermenu/powermenu.sh"
    },
    "custom/search": {
        "format": "󰍉 ",
        "tooltip": false,
        "on-click": "~/.config/rofi/launchers/launcher.sh"
    },
    "hyprland/workspaces": {
        "all-outputs": false,
        "format": "{name}",
        "on-scroll-up": "hyprctl dispatch workspace e+1 1>/dev/null",
        "on-scroll-down": "hyprctl dispatch workspace e-1 1>/dev/null",
        "sort-by-number": false,
        "active-only": false,
        "show-special": false
    },
    "cpu": {
        "interval": 1,
        "format": "󰘚 {usage:>3}%",
        "tooltip-format": "CPU Usage: {usage}%\nFrequency: {max_frequency}GHz",
        "max-length": 10,
        "on-click": "alacritty -e btop"
    },
    "custom/gpu": {
        "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits | awk '{printf \"󰢮 %3s%%\", $1}'",
        "format": "{}",
        "interval": 1,
        "tooltip": false,
        "on-click": "alacritty -e btop"
    },
    "memory": {
        "interval": 1,
        "format": "󰍛 {percentage:>3}%",
        "tooltip-format": "Memory: {used:0.1f}GB / {total:0.1f}GB ({percentage}%)",
        "max-length": 10,
        "on-click": "alacritty -e btop"
    },
    "disk": {
        "interval": 1,
        "format": "󰋊 {percentage_used:>3}%",
        "path": "/",
        "tooltip-format": "Disk: {used} / {total} ({percentage_used}%)",
        "max-length": 10,
        "on-click": "alacritty -e btop"
    },
    "tray": {
        "icon-size": 14,
        "spacing": 24,
        "show-passive-items": true,
        "reverse-direction": false
    },
    "custom/sound": {
        "format": "󰕾",
        "tooltip": "Sound Control",
        "on-click": "pavucontrol"
    },
    "battery": {
        "interval": 1,
        "format": "󰁹 {capacity:>3}%",
        "format-charging": "󰂄 {capacity:>3}%",
        "format-plugged": "󰂄 {capacity:>3}%",
        "format-critical": "󰂃 {capacity:>3}%",
        "tooltip-format": "Battery: {capacity}% ({time})",
        "states": {
            "warning": 30,
            "critical": 15
        },
        "max-length": 10
    },
    "clock": {
        "format": "{:%a %d %b %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "today-format": "<b>{}</b>"
    }
}
