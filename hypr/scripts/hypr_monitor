#!/usr/bin/env bash

# Find active external monitor and move all workspaces to it
MONITOR=$(hyprctl monitors | grep -E "DP-2|DP-3|HDMI-A-1" | head -1 | awk '{print $2}' | sed 's/://')

if [ -n "$MONITOR" ]; then
    # Get the highest refresh rate available for 1920x1080 resolution
    HIGHEST_MODE=$(hyprctl monitors all | grep -A 100 "Monitor $MONITOR" | grep "availableModes:" | tr ' ' '\n' | grep "1920x1080@" | sort -t@ -k2 -nr | head -1)

    if [ -n "$HIGHEST_MODE" ]; then
        # Extract resolution and refresh rate, format as resolution@rate
        RESOLUTION=$(echo "$HIGHEST_MODE" | sed 's/Hz$//')
        echo "Setting $MONITOR to $RESOLUTION"

        # Remove any existing monitor line for this external monitor
        sed -i "/^monitor = $MONITOR,/d" ~/.config/hypr/config/monitor.conf

        # Add persistent monitor configuration at the top of the file (after the laptop monitor line)
        sed -i "/^monitor = eDP-1,/a monitor = $MONITOR, $RESOLUTION, auto, 1" ~/.config/hypr/config/monitor.conf

        # Apply the configuration immediately
        hyprctl keyword monitor "$MONITOR, $RESOLUTION, auto, 1"
    else
        # Fallback to preferred if we can't determine the mode
        sed -i "/^monitor = $MONITOR,/d" ~/.config/hypr/config/monitor.conf
        sed -i "/^monitor = eDP-1,/a monitor = $MONITOR, preferred, auto, 1" ~/.config/hypr/config/monitor.conf
        hyprctl keyword monitor "$MONITOR, preferred, auto, 1"
    fi

    # Update workspace rules in monitor.conf to use the detected external monitor
    # Exclude workspace 11 which should always stay on eDP-1
    sed -i "/workspace = 11,/!s/monitor:eDP-1/monitor:$MONITOR/g" ~/.config/hypr/config/monitor.conf
    sed -i "/workspace = 11,/!s/monitor:DP-2/monitor:$MONITOR/g" ~/.config/hypr/config/monitor.conf
    sed -i "/workspace = 11,/!s/monitor:DP-3/monitor:$MONITOR/g" ~/.config/hypr/config/monitor.conf
    sed -i "/workspace = 11,/!s/monitor:HDMI-A-1/monitor:$MONITOR/g" ~/.config/hypr/config/monitor.conf

    # Get all workspace names and move them to external monitor
    WORKSPACES=$(hyprctl workspaces | grep "workspace ID" | awk '{print $4}' | sed 's/[():]//g')

    for workspace in $WORKSPACES; do
        # Skip workspace 11 (keep on laptop)
        if [ "$workspace" != "11" ]; then
            hyprctl dispatch moveworkspacetomonitor "$workspace" "$MONITOR"
        fi
    done

    # Focus the external monitor
    hyprctl dispatch focusmonitor "$MONITOR"
else
    # Remove any external monitor configurations when disconnected
    sed -i "/^monitor = DP-2,/d" ~/.config/hypr/config/monitor.conf
    sed -i "/^monitor = DP-3,/d" ~/.config/hypr/config/monitor.conf
    sed -i "/^monitor = HDMI-A-1,/d" ~/.config/hypr/config/monitor.conf

    # Update workspace rules in monitor.conf to use laptop monitor
    # Exclude workspace 11 which should always stay on eDP-1
    sed -i "/workspace = 11,/!s/monitor:DP-2/monitor:eDP-1/g" ~/.config/hypr/config/monitor.conf
    sed -i "/workspace = 11,/!s/monitor:DP-3/monitor:eDP-1/g" ~/.config/hypr/config/monitor.conf
    sed -i "/workspace = 11,/!s/monitor:HDMI-A-1/monitor:eDP-1/g" ~/.config/hypr/config/monitor.conf

    # Get all workspace names and move them to laptop
    WORKSPACES=$(hyprctl workspaces | grep "workspace ID" | awk '{print $4}' | sed 's/[():]//g')

    for workspace in $WORKSPACES; do
        echo "Moving workspace $workspace to eDP-1"
        hyprctl dispatch moveworkspacetomonitor "$workspace" "eDP-1"
    done

    # Focus the laptop monitor
    hyprctl dispatch focusmonitor "eDP-1"
fi
