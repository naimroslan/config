#!/usr/bin/env bash

# Find active external monitor and move all workspaces to it
MONITOR=$(hyprctl monitors | grep -E "DP-2|DP-3|HDMI-A-1" | head -1 | awk '{print $2}' | sed 's/://')

if [ -n "$MONITOR" ]; then
    echo "Found external monitor: $MONITOR"
    echo "Moving all workspaces to $MONITOR (except workspace 11)"

    # Get the highest refresh rate for 1920x1080 resolution
    REFRESH_RATE=$(wlr-randr | grep -A 20 "$MONITOR" | grep "1920x1080 px," | grep -o '[0-9]\+\.[0-9]\+' | sort -nr | head -1)

    echo "Using best mode: 1920x1080 @ ${REFRESH_RATE}Hz"

    # Set external monitor to best resolution and refresh rate
    hyprctl keyword monitor "$MONITOR, 1920x1080@${REFRESH_RATE}, 1920x0, 1"

    # Move all numbered workspaces 1-10 to external monitor
    for i in {1..10}; do
        hyprctl dispatch moveworkspacetomonitor "$i $MONITOR"
    done

    # Move all letter workspaces to external monitor
    for letter in {A..Z}; do
        hyprctl dispatch moveworkspacetomonitor "$letter $MONITOR"
    done

    # Ensure workspace 11 stays on laptop
    hyprctl dispatch moveworkspacetomonitor "11 eDP-1"

    # Focus the external monitor
    hyprctl dispatch focusmonitor "$MONITOR"
else
    echo "No external monitor found, moving all workspaces to laptop display"

    # Move all numbered workspaces to laptop
    for i in {1..10}; do
        hyprctl dispatch moveworkspacetomonitor "$i eDP-1"
    done

    # Move all letter workspaces to laptop
    for letter in {A..Z}; do
        hyprctl dispatch moveworkspacetomonitor "$letter eDP-1"
    done

    # Ensure workspace 11 stays on laptop
    hyprctl dispatch moveworkspacetomonitor "11 eDP-1"

    # Focus the laptop monitor
    hyprctl dispatch focusmonitor "eDP-1"
fi
