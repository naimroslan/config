#!/usr/bin/env bash

# Watch for display changes and run monitor scripts
echo "Starting monitor watcher..."

# Function to run monitor scripts
run_monitor_scripts() {
    echo "Display change detected, running monitor scripts..."
    ~/.config/hypr/scripts/hypr_monitor
    ~/.config/hypr/scripts/waybar_monitor
}

# Watch for changes in the monitor configuration
while true; do
    # Get current monitor count
    CURRENT_MONITORS=$(hyprctl monitors | grep -c "Monitor")

    # Wait for a change in monitor count
    while true; do
        NEW_MONITORS=$(hyprctl monitors | grep -c "Monitor")
        if [ "$CURRENT_MONITORS" != "$NEW_MONITORS" ]; then
            echo "Monitor count changed from $CURRENT_MONITORS to $NEW_MONITORS"
            run_monitor_scripts
            CURRENT_MONITORS=$NEW_MONITORS
            break
        fi
        sleep 0.1
    done
done
